#!/usr/bin/env bash
#
# Pre-commit hook:
#   1. ruff format (auto-applied + re-staged)
#   2. ruff check (blocks on failure)
#   3. pyright (warning only — catches type drift without blocking)
#   4. pytest --collect-only (warning only — catches import/syntax breakage)
#
# Each tool is soft-failed if not installed; missing .venv tools fall back to PATH.

set -euo pipefail

PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(src|tests)/.*\.py$' || true)

if [ -z "$PYTHON_FILES" ]; then
    exit 0
fi

resolve_tool() {
    local tool_name="$1"
    if [ -f ".venv/bin/${tool_name}" ]; then
        printf '%s\n' ".venv/bin/${tool_name}"
        return 0
    fi
    if [ -f ".venv/Scripts/${tool_name}.exe" ] && ! grep -qi microsoft /proc/version 2>/dev/null; then
        printf '%s\n' ".venv/Scripts/${tool_name}.exe"
        return 0
    fi
    if [ -f ".venv/Scripts/${tool_name}" ] && ! grep -qi microsoft /proc/version 2>/dev/null; then
        printf '%s\n' ".venv/Scripts/${tool_name}"
        return 0
    fi
    if command -v "${tool_name}" &>/dev/null; then
        command -v "${tool_name}"
        return 0
    fi
    return 1
}

# --- Phase 1: ruff format + lint (blocking on lint failure) ---
if ! RUFF=$(resolve_tool ruff); then
    echo "WARNING: ruff not found in .venv or PATH — skipping format/lint checks"
else
    echo "Running ruff format..."
    echo "$PYTHON_FILES" | xargs "$RUFF" format --config pyproject.toml
    echo "$PYTHON_FILES" | xargs git add

    echo "Running ruff check..."
    if ! echo "$PYTHON_FILES" | xargs "$RUFF" check --config pyproject.toml; then
        echo ""
        echo "COMMIT BLOCKED: ruff lint errors found (see above)"
        exit 1
    fi
fi

# --- Phase 2: pyright (warning only) ---
if PYRIGHT=$(resolve_tool pyright); then
    echo "Running pyright..."
    if ! PYRIGHT_OUTPUT=$("$PYRIGHT" src/ 2>&1); then
        echo "WARNING: pyright reported type issues (not blocking commit):"
        echo "$PYRIGHT_OUTPUT" | tail -20
    fi
fi

# --- Phase 3: pytest collection smoke (warning only) ---
if PYTEST=$(resolve_tool pytest); then
    echo "Running pytest --collect-only..."
    if ! PYTEST_OUTPUT=$("$PYTEST" -q --collect-only 2>&1); then
        echo "WARNING: pytest collection failed (likely import/syntax error):"
        echo "$PYTEST_OUTPUT" | tail -20
    fi
fi

exit 0
